# eBay Developer Credentials
# Get these from https://developer.ebay.com after registering
EBAY_APP_ID=your_app_id_here
EBAY_CERT_ID=your_cert_id_here
EBAY_DEV_ID=your_dev_id_here

# eBay Auth'N'Auth Token (18-month lifetime)
# Get from eBay account Settings > Application Access
EBAY_AUTH_TOKEN=your_auth_token_here

# --- OAuth credentials (Phase 2 + Phase 3 tools) ---
# Same values as EBAY_APP_ID / EBAY_CERT_ID but MUST be set under the OAuth-named
# keys (ebay/oauth.py reads from these specific names; it does not fall back —
# fail-fast enforced by tests/test_oauth.py). Used by: find_competitor_prices
# (Browse API), get_traffic_report (REST Analytics), get_listing_returns +
# compute_return_rate (Post-Order v2).
EBAY_APP_CLIENT_ID=same_as_EBAY_APP_ID
EBAY_APP_CLIENT_SECRET=same_as_EBAY_CERT_ID

# OAuth redirect URL (RuName) registered in the Dev Portal. Required for the
# scripts/oauth_setup.py one-time consent flow ONLY (not runtime).
EBAY_OAUTH_RU_NAME=your_ru_name_here

# OAuth refresh token. Leave blank on first setup — scripts/oauth_setup.py
# writes this back after consent completes. 18-month lifetime; re-run
# oauth_setup.py to refresh.
EBAY_OAUTH_REFRESH_TOKEN=

# Own-seller exclusion for Browse-API competitor scans. Without this,
# find_competitor_prices silently returns own listings in the result set.
EBAY_OWN_SELLER_USERNAME=your_ebay_username_here

# eBay UK marketplace
EBAY_SITE_ID=3

# Required for AddFixedPriceItem / create_listing — hard-fail per ebay/auth.py
# REQUIRED_VARS. Boot exits with SystemExit(1) if either is unset or empty.
# Used by ebay/listings.py:499-500 as the default location_details block.
EBAY_SELLER_LOCATION=Coventry
EBAY_SELLER_POSTCODE=CV1 1AN

# --- Business Policies Profile IDs (issue #29) — DEPRECATED 2026-05-26 ---
# Per the 2026-05-26 permanent fix (3-incident shipping-poison history),
# build_add_payload + build_revise_payload no longer attach ANY SellerProfiles
# block to Trading API payloads. `_REQUIRED_SELLER_PROFILE_ENV_VARS = ()` in
# ebay/listings.py — these env vars are NOT required at runtime any more.
# Source of truth: account-level eBay Simple Delivery + manually-set free
# shipping. See feedback_ebay_default_shipping_poisoned.md + ebay/listings.py
# "SellerProfiles attachment policy" module docstring.
#
# These three keys are retained in .env.example for transitional / archaeology
# reasons only — leave them BLANK. Setting them does nothing in the add/revise
# code paths. (scripts/apply_returns_policy.py is hard-refused regardless.)
EBAY_PAYMENT_PROFILE_ID=
EBAY_SHIPPING_PROFILE_ID=
EBAY_RETURN_PROFILE_ID=

# --- Optional overrides (defaults below are used when unset) ---
# eBay marketplace code for Browse API + Traffic Report scope. Used by
# ebay/oauth.py:219,233. Default EBAY_GB — override for other regions.
# EBAY_MARKETPLACE_ID=EBAY_GB
# OAuth token + REST endpoint root. Used by ebay/oauth.py:39. Override
# with https://api.sandbox.ebay.com for sandbox testing.
# EBAY_OAUTH_BASE_URL=https://api.ebay.com

# Set to 1 to enable verbose ebaysdk request/response logging
# EBAY_DEBUG=1

# Set to true to use eBay Sandbox endpoint (api.sandbox.ebay.com) for testing
# write operations without affecting your real store. Default: false (production).
# EBAY_SANDBOX=false

# Local Google Drive root for HTML listing files (used by skill audit/sync scripts).
# Set this to wherever your product folders live on disk.
# EBAY_DRIVE_ROOT=/path/to/your/Hard Disks
